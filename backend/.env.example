DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wo
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/wo
STORAGE_ROOT=./storage
# MAX_UPLOAD_BYTES=20971520  # 20 MB default
# MEMORY_VIDEO_MAX_BYTES=104857600  # 回忆短视频上限，100 MB default
# 应用内更新发布密钥；空则关闭 POST /app/release。本地调试可随意设。
# APP_RELEASE_TOKEN=dev-release-token
# TMDB（看电影插件的简介/评分/海报来源）。任一鉴权即可：优先 v4 Read Access Token，
# 否则用 v3 API key（注册 themoviedb.org 后一并发放）。两者都留空则补充会标记为失败。
# 国内服务器若无法直连 api.themoviedb.org / image.tmdb.org，把下面两个 base_url 指向反代。
# TMDB_ACCESS_TOKEN=
# TMDB_API_KEY=
# TMDB_BASE_URL=https://api.themoviedb.org/3
# TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
# AI 模型配置现在按家庭存储（我的 → 设置 → AI 集成设置），密钥加密入库。
# AI_SECRET_KEY 是加密这些密钥的对称密钥（Fernet），必须设置才能保存 API Key。生成：
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# AI_SECRET_KEY=
# 下面 KIMI_* 已废弃：仅作「一次性迁移种子」——某家庭首次用 AI 时若没配多模态且这里有值，
# 会自动迁移成该家庭的多模态配置（加密入库）。迁移完成后可删除。
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.6
