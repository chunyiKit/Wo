# Production app env template. setup-server.sh writes a real /etc/wo/app.env
# with these defaults — edit it on the server and `systemctl restart wo-backend`
# to apply.

DEBUG=false

# Where photo blobs land. Anything under /var/lib/wo is reserved for the wo user.
STORAGE_ROOT=/var/lib/wo/storage

# Used to build invitation links + the photo URL prefix the client sees.
# Swap for https://your.domain once TLS is set up.
WEB_BASE_URL=http://122.51.81.235

# Per-upload cap (bytes). Must stay ≤ nginx `client_max_body_size`.
MAX_UPLOAD_BYTES=20971520

# 回忆插件的短视频单独上限（bytes，默认 100 MB）。须 ≤ nginx 中
# /plugins/memory/ location 的 client_max_body_size。
MEMORY_VIDEO_MAX_BYTES=104857600

# 应用内更新（Android APK 发布）的共享密钥。空 = 关闭发布接口（POST /app/release
# 返回 403）。设一个随机串，发布脚本用它做 X-Release-Token。
# 生成：openssl rand -hex 24
APP_RELEASE_TOKEN=

# ---- COS (腾讯云对象存储) -------------------------------------------------
# 配齐这四个变量后，APK 发布会上传到 COS，App 直接从 COS 公共域名拉取，不再
# 吃 CVM 的下行带宽。留空则继续走本地盘 + /app/download（开发/测试默认行为）。
#
# 强烈建议在 CAM 新建子账号密钥，只授予「该 bucket 的写权限（cos:PutObject）」，
# 不要用主账号密钥。
COS_BUCKET=
COS_REGION=
COS_SECRET_ID=
COS_SECRET_KEY=
# APK 对象在 bucket 内的前缀，默认 app-release/ 即可。
COS_APK_PREFIX=app-release

# ---- 推送 & 后台提醒开关 --------------------------------------------------
# 这些开关默认 false（开发/测试不跑后台循环）。生产要让手机收到推送 + 定时
# 提醒，需在此打开并 `systemctl restart wo-backend`。
#
# 推送总开关：true 时通知才会进推送 outbox 并下发到 JPush。
PUSH_ENABLED=false
# JPush 凭据（Push API v3，HTTP Basic：app_key:master_secret）。留空则推送 no-op。
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
# iOS APNs 网关：false=sandbox（dev 包），true=production。
JPUSH_APNS_PRODUCTION=false
# 纪念日到期提醒循环。
ANNIVERSARY_REMINDER_ENABLED=false
# 记账月末结余提醒循环（每月最后一天 21:00）。
ACCOUNTING_MONTHLY_NOTICE_ENABLED=false
# 囤货铺每周盘点提醒循环（每周六 20:00，提醒全家盘点囤货）。
STOCK_WEEKLY_NOTICE_ENABLED=false
# 家历日程到期提醒循环（在每条日程下次发生前 N 天推送）。
CALENDAR_REMINDER_ENABLED=false
# 订阅管家到期提醒 + 自动记账循环（到期前提醒，到期日自动记入「记账」并顺延）。
SUBSCRIPTION_REMINDER_ENABLED=false
# 到期管家提醒循环（证件 / 年检 / 保险 / 合同：到期前 N 天提醒，过期再提醒一次）。
EXPIRY_REMINDER_ENABLED=false

# ---- AI（插件可调用的通用大模型模块）----
# 当前支持 Kimi（Moonshot，OpenAI 兼容接口）。留空 KIMI_API_KEY 时调用方会收到
# 「未配置」错误，不会真的发请求。国内服务器用 .cn 端点；国际平台改 .ai 端点。
# 请求认证：生产环境关闭 X-User-Id 调试通道，只认登录签发的 Bearer 会话令牌。
AUTH_DEV_SHIM_ENABLED=false

AI_PROVIDER=kimi
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
# kimi-k2.6 为多模态（视觉）模型，植物插件等需要发图片分析时必须用它；纯文本调用也兼容。
KIMI_MODEL=kimi-k2.6

# ---- Weather（插件可调用的通用天气模块）----
# 当前支持 QWeather（和风天气）。留空 QWEATHER_API_KEY 时调用方会收到「未配置」
# 错误并降级（如植物插件改为仅看图分析），不会真的发请求。免费开发版用 devapi
# 端点；付费/JWT 方案改用专属 host。天气变化慢，按地点缓存以省额度。
WEATHER_PROVIDER=qweather
QWEATHER_API_KEY=
# 必须带 /v7 版本段(代码在其后拼 /weather/now)。新版控制台账号有「专属 API Host」,
# 在共享 devapi 上会报 403 Invalid Host —— 改成 https://你的专属host.qweatherapi.com/v7;
# 漏掉 /v7 会报 404。老免费账号用下面这个共享 host。
QWEATHER_BASE_URL=https://devapi.qweather.com/v7
WEATHER_CACHE_TTL_SECONDS=1800
