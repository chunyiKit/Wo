# Production app env template. setup-server.sh writes a real /etc/wo/app.env
# with these defaults — edit it on the server and `systemctl restart wo-backend`
# to apply.

DEBUG=false

# Where photo blobs land. Anything under /var/lib/wo is reserved for the wo user.
STORAGE_ROOT=/var/lib/wo/storage

# Used to build invitation links + the photo URL prefix the client sees.
# Swap for https://your.domain once TLS is set up.
WEB_BASE_URL=http://122.51.81.235

# Per-upload cap (bytes). Must stay ≤ nginx `client_max_body_size`.
MAX_UPLOAD_BYTES=20971520
