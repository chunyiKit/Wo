<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ 深色：背景 @color/wo_splash_bg 解析到 ink，标记解析到 cream。 -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/wo_splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/wo_splash_mark</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/wo_splash_bg</item>
    </style>
</resources>
